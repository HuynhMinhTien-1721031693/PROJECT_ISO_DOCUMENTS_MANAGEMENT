@page "/new-document"
@attribute [Authorize]
@inject DocumentApiService DocumentApiService
@inject NavigationManager Navigation

<div style="margin-bottom:16px;">
    <a class="btn secondary" href="/documents">← Quay lại danh sách</a>
</div>

<h1>Tải lên tài liệu mới</h1>
<p class="muted">Hỗ trợ file PDF, DOCX, XLSX (tối đa 50MB). Mã tài liệu theo mẫu <code>QMS-PR-001</code>.</p>

<UploadForm Model="Model"
            Busy="Busy"
            ShowError="_hasSubmitAttempt"
            Error="@Error"
            SelectedFileName="@_selectedFile?.Name"
            FileChanged="OnFileChanged"
            OnSubmit="HandleSubmitAsync" />

@if (!string.IsNullOrWhiteSpace(Success))
{
    <p style="margin-top: 10px; color: #166534;">@Success</p>
}

@code {
    private readonly UploadFormModel Model = new();
    private IBrowserFile? _selectedFile;
    private bool _hasSubmitAttempt;
    private bool Busy { get; set; }
    private string Error { get; set; } = string.Empty;
    private string Success { get; set; } = string.Empty;

    private Task OnFileChanged(IBrowserFile? file)
    {
        _selectedFile = file;
        return Task.CompletedTask;
    }

    private async Task HandleSubmitAsync()
    {
        _hasSubmitAttempt = true;
        Error = string.Empty;
        Success = string.Empty;

        if (_selectedFile is null)
        {
            Error = "Vui lòng chọn file upload.";
            return;
        }

        var ext = Path.GetExtension(_selectedFile.Name).ToLowerInvariant();
        var allowedExt = new[] { ".pdf", ".docx", ".xlsx" };
        if (!allowedExt.Contains(ext))
        {
            Error = "Định dạng file không hợp lệ. Chỉ chấp nhận PDF/DOCX/XLSX.";
            return;
        }

        if (_selectedFile.Size > 50 * 1024 * 1024)
        {
            Error = "File vượt quá 50MB.";
            return;
        }

        Busy = true;
        try
        {
            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);

            var tags = Model.TagsRaw
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToArray();

            var (id, error) = await DocumentApiService.UploadAsync(
                Model.Title,
                Model.DocumentCode,
                Model.Standard,
                Model.Category,
                Model.Description,
                Model.ChangeNote,
                tags,
                stream,
                _selectedFile.Name,
                _selectedFile.ContentType,
                CancellationToken.None);

            if (!string.IsNullOrWhiteSpace(error))
            {
                Error = BuildUploadErrorMessage(error);
                return;
            }

            if (id is not null)
                Navigation.NavigateTo($"/documents/{id}");
            else
                Success = "Upload thành công.";
        }
        catch (Exception ex)
        {
            Error = BuildUploadErrorMessage(ex.Message);
        }
        finally
        {
            Busy = false;
        }
    }

    private static string BuildUploadErrorMessage(string? rawError)
    {
        var formatted = ApiProblemMessageFormatter.Format(rawError);
        if (string.IsNullOrWhiteSpace(formatted))
            return "Không thể tải lên tài liệu. Vui lòng kiểm tra định dạng file, dung lượng và thử lại.";

        return formatted;
    }
}
