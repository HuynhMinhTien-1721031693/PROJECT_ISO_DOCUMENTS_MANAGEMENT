  },
  "Auth": {
    "SeedUsersFromConfig": false,
    "AllowPlainTextForDev": false,
    "MaxFailedAttempts": 5,
    "FailedAttemptWindowMinutes": 15,
    "LockoutMinutes": 15,
    "Users": []
  },
  "RateLimiting": {
    "LoginPermitPerMinute": 40
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5062",
      "https://localhost:7065",
      "http://localhost:5000",
      "https://localhost:5001",
      "https://localhost:7172"
    ]
