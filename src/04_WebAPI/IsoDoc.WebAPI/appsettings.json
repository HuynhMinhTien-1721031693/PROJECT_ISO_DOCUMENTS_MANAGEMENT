{
  "ConnectionStrings": {
    "SqlServer": "",
    "Redis": "",
    "AzureBlob": ""
  },
  "BlobStorage": {
    "ConnectionString": "",
    "ContainerName": "iso-documents",
    "SasExpiryHours": 1,
    "UseLocalDisk": false,
    "LocalDiskRootPath": ""
  },
  "IsoDoc": {
    "AzureBlob": {
      "ConnectionString": "",
      "ContainerName": "documents"
    },
    "Elasticsearch": {
      "Uri": "",
      "IndexName": "iso-documents",
      "ParticipateInHealthChecks": false
    },
    "Jwt": {
      "Issuer": "IsoDoc",
      "Audience": "IsoDoc.Api",
      "SigningKey": "CHANGE_ME_32CHAR_MINIMUM_SECRET_KEY!!",
      "AccessTokenMinutes": 60
    }
  },
  "Notifications": {
    "EnableSmtp": false,
    "EnableSignalR": true,
    "SmtpHost": "localhost",
    "SmtpPort": 587,
    "UseStartTls": true,
    "SkipServerCertificateValidation": false,
    "SmtpUser": "",
    "SmtpPass": "",
    "FromAddress": "noreply@example.local",
