<div class="card filters">
    <p class="tiny" style="margin:0 0 8px 0;">Mẹo: nhập vài ký tự trong tiêu đề hoặc mã tài liệu để lọc nhanh, sau đó bấm <strong>Lọc dữ liệu</strong>.</p>
    <div class="field">
        <label>Từ khóa</label>
        <input placeholder="Nhập tiêu đề hoặc mã tài liệu" @bind="Model.Keyword" />
    </div>
    <div class="field">
        <label>Trạng thái</label>
        <select @bind="Model.Status">
            <option value="">Tất cả</option>
            <option>Draft</option>
            <option>UnderReview</option>
            <option>PendingFinalApproval</option>
            <option>Published</option>
            <option>Rejected</option>
            <option>Archived</option>
        </select>
    </div>
    <div class="field">
        <label>Tiêu chuẩn ISO</label>
        <select @bind="Model.Standard">
            <option value="">Tất cả</option>
            <option>ISO9001</option>
            <option>ISO45001</option>
            <option>ISO27001</option>
        </select>
    </div>
    <div class="field">
        <label>Phân loại</label>
        <select @bind="Model.Category">
            <option value="">Tất cả</option>
            <option>Policy</option>
            <option>Procedure</option>
            <option>WorkInstruction</option>
            <option>Form</option>
            <option>Record</option>
            <option>Manual</option>
            <option>Specification</option>
        </select>
    </div>
    <div class="field">
        <label>Cập nhật từ</label>
        <InputDate @bind-Value="Model.FromDate" class="input-date" />
    </div>
    <div class="field">
        <label>Đến</label>
        <InputDate @bind-Value="Model.ToDate" class="input-date" />
    </div>
    <div class="field">
        <label>Sắp xếp</label>
        <select @bind="Model.SortBy">
            <option value="UpdatedAt">Ngày cập nhật</option>
            <option value="CreatedAt">Ngày tạo</option>
            <option value="Title">Tiêu đề</option>
            <option value="DocumentCode">Mã tài liệu</option>
            <option value="Status">Trạng thái</option>
        </select>
    </div>
    <div class="field">
        <label>Số dòng/trang</label>
        <select @bind="Model.PageSize">
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50">50</option>
        </select>
    </div>
    <div class="actions">
        <button class="btn" @onclick="Apply">Lọc dữ liệu</button>
        <button class="btn secondary" @onclick="Reset">Đặt lại bộ lọc</button>
    </div>
</div>

@code {
    [Parameter] public SearchDocumentsParams Model { get; set; } = new();
    [Parameter] public EventCallback OnApply { get; set; }

    private async Task Apply()
    {
        Model.Page = 1;
        await OnApply.InvokeAsync();
    }

    private async Task Reset()
    {
        Model.Keyword = null;
        Model.Status = null;
        Model.Category = null;
        Model.Standard = null;
        Model.FromDate = null;
        Model.ToDate = null;
        Model.OwnerId = null;
        Model.SortBy = "UpdatedAt";
        Model.SortDesc = true;
        Model.PageSize = 20;
        Model.Page = 1;
        await OnApply.InvokeAsync();
    }
}
