@inject NavigationManager NavigationManager

<div class="card">
    <table class="doc-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Title</th>
                <th>ISO</th>
                <th>Status</th>
                <th>Version</th>
                <th>Owner</th>
                <th>Updated</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Items.Count == 0)
            {
                <tr>
                    <td colspan="8">Không có dữ liệu.</td>
                </tr>
            }
            else
            {
                @foreach (var doc in Items)
                {
                    <tr>
                        <td>@doc.DocumentCode</td>
                        <td>@doc.Title</td>
                        <td>@doc.IsoStandard</td>
                        <td><StatusBadge Status="@doc.Status" /></td>
                        <td>@doc.CurrentVersion</td>
                        <td>@doc.OwnerName</td>
                        <td>@doc.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>
                            <button class="btn-link" @onclick="() => OpenDetail(doc.Id)">Detail</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public IReadOnlyList<DocumentSummaryDto> Items { get; set; } = Array.Empty<DocumentSummaryDto>();

    private void OpenDetail(Guid id) => NavigationManager.NavigateTo($"/documents/{id}");
}
