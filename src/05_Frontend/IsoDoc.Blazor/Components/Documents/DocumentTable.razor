<div class="card">
    <table class="doc-table">
        <thead>
            <tr>
                <th>Mã tài liệu</th>
                <th>Tiêu đề</th>
                <th>ISO</th>
                <th>Trạng thái</th>
                <th>Phiên bản</th>
                <th>Phụ trách</th>
                <th>Cập nhật</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Items.Count == 0)
            {
                <tr>
                    <td colspan="8">Không có dữ liệu.</td>
                </tr>
            }
            else
            {
                @foreach (var doc in Items)
                {
                    <tr>
                        <td><a class="iso-doc-code" href="@($"/documents/{doc.Id}")">@doc.DocumentCode</a></td>
                        <td><a class="btn-link" href="@($"/documents/{doc.Id}")">@doc.Title</a></td>
                        <td>@doc.IsoStandard</td>
                        <td><StatusBadge Status="@doc.Status" /></td>
                        <td>@doc.CurrentVersion</td>
                        <td>@doc.OwnerName</td>
                        <td>@doc.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>
                            <a class="btn-link" href="@($"/documents/{doc.Id}")">Chi tiết</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public IReadOnlyList<DocumentSummaryDto> Items { get; set; } = Array.Empty<DocumentSummaryDto>();
}
