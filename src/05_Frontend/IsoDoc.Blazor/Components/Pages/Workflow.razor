@page "/workflow"
@attribute [Authorize]
@inject WorkflowApiService WorkflowApiService

<h1>Danh sách chờ duyệt</h1>
<p class="muted">Dành cho người có quyền phê duyệt. Bạn có thể duyệt nhanh ngay tại bảng.</p>

<div class="field" style="max-width:520px;margin-bottom:12px;">
    <label>Lý do từ chối (khi bấm Từ chối nhanh)</label>
    <textarea @bind="RejectComment" rows="2" placeholder="Bắt buộc khi từ chối…"></textarea>
</div>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <p class="error-banner" style="margin: 10px 0;">@Error</p>
}

<div class="card">
    <table class="doc-table">
        <thead>
            <tr>
                <th>Tài liệu</th>
                <th>ISO</th>
                <th>Người gửi</th>
                <th>Bước duyệt</th>
                <th>Số ngày chờ</th>
                <th>Chi tiết</th>
                <th>Quyết định</th>
            </tr>
        </thead>
        <tbody>
            @if (Items.Count == 0)
            {
                <tr><td colspan="7">Hiện chưa có mục nào chờ duyệt.</td></tr>
            }
            else
            {
                @foreach (var item in Items)
                {
                    <tr>
                        <td>
                            <a class="btn-link" href="@($"/documents/{item.DocumentId}")">@item.DocumentCode</a>
                            <span class="muted"> — </span>
                            <a class="btn-link" href="@($"/documents/{item.DocumentId}")">@item.DocumentTitle</a>
                        </td>
                        <td>@item.IsoStandard</td>
                        <td>@item.SubmittedByName</td>
                        <td>@item.StepOrder/@item.TotalSteps</td>
                        <td>@item.DaysWaiting</td>
                        <td><a href="@($"/workflow/{item.WorkflowId}")">Xem</a></td>
                        <td class="workflow-actions">
                            <button class="btn" disabled="@BusyWorkflowId.HasValue" @onclick='() => Decide(item.WorkflowId, "Approved")'>Duyệt</button>
                            <button class="btn secondary" disabled="@BusyWorkflowId.HasValue" @onclick='() => Decide(item.WorkflowId, "Rejected")'>Từ chối</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    private IReadOnlyList<PendingApprovalDto> Items { get; set; } = Array.Empty<PendingApprovalDto>();
    private string Error { get; set; } = string.Empty;
    private Guid? BusyWorkflowId { get; set; }
    private string RejectComment { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var (items, _, error) = await WorkflowApiService.GetPendingAsync();
        Items = items;
        Error = error ?? string.Empty;
    }

    private async Task Decide(Guid workflowId, string decision)
    {
        if (decision == "Rejected" && string.IsNullOrWhiteSpace(RejectComment))
        {
            Error = "Vui lòng nhập lý do trước khi từ chối.";
            return;
        }

        BusyWorkflowId = workflowId;
        var comment = decision == "Rejected"
            ? RejectComment.Trim()
            : $"{decision} (danh sách nhanh)";
        var (ok, error) = await WorkflowApiService.DecideAsync(workflowId, decision, comment);
        BusyWorkflowId = null;
        if (!ok)
            Error = error ?? "Không thể lưu quyết định. Vui lòng thử lại.";
        else
        {
            RejectComment = string.Empty;
            await LoadAsync();
        }
    }
}
