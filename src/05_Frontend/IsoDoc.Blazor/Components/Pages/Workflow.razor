@page "/workflow"
@attribute [Authorize]
@inject WorkflowApiService WorkflowApiService

<h1>Pending Workflow</h1>
<p class="muted">Dành cho vai trò approver.</p>

<div class="field" style="max-width:520px;margin-bottom:12px;">
    <label>Lý do từ chối (dùng khi bấm Reject nhanh tại đây)</label>
    <textarea @bind="RejectComment" rows="2" placeholder="Bắt buộc khi từ chối…"></textarea>
</div>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <p class="error-banner" style="margin: 10px 0;">@Error</p>
}

<div class="card">
    <table class="doc-table">
        <thead>
            <tr>
                <th>Document</th>
                <th>ISO</th>
                <th>Submitted By</th>
                <th>Step</th>
                <th>Days Waiting</th>
                <th>Chi tiết</th>
                <th>Quyết định</th>
            </tr>
        </thead>
        <tbody>
            @if (Items.Count == 0)
            {
                <tr><td colspan="7">Không có task workflow.</td></tr>
            }
            else
            {
                @foreach (var item in Items)
                {
                    <tr>
                        <td>@item.DocumentCode - @item.DocumentTitle</td>
                        <td>@item.IsoStandard</td>
                        <td>@item.SubmittedByName</td>
                        <td>@item.StepOrder/@item.TotalSteps</td>
                        <td>@item.DaysWaiting</td>
                        <td><a href="@($"/workflow/{item.WorkflowId}")">Xem</a></td>
                        <td class="workflow-actions">
                            <button class="btn" disabled="@BusyWorkflowId.HasValue" @onclick='() => Decide(item.WorkflowId, "Approved")'>Approve</button>
                            <button class="btn secondary" disabled="@BusyWorkflowId.HasValue" @onclick='() => Decide(item.WorkflowId, "Rejected")'>Reject</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    private IReadOnlyList<PendingApprovalDto> Items { get; set; } = Array.Empty<PendingApprovalDto>();
    private string Error { get; set; } = string.Empty;
    private Guid? BusyWorkflowId { get; set; }
    private string RejectComment { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var (items, _, error) = await WorkflowApiService.GetPendingAsync();
        Items = items;
        Error = error ?? string.Empty;
    }

    private async Task Decide(Guid workflowId, string decision)
    {
        if (decision == "Rejected" && string.IsNullOrWhiteSpace(RejectComment))
        {
            Error = "Nhập lý do từ chối trước khi reject.";
            return;
        }

        BusyWorkflowId = workflowId;
        var comment = decision == "Rejected"
            ? RejectComment.Trim()
            : $"{decision} (danh sách nhanh)";
        var (ok, error) = await WorkflowApiService.DecideAsync(workflowId, decision, comment);
        BusyWorkflowId = null;
        if (!ok)
            Error = error ?? "Không thể ghi quyết định.";
        else
        {
            RejectComment = string.Empty;
            await LoadAsync();
        }
    }
}
