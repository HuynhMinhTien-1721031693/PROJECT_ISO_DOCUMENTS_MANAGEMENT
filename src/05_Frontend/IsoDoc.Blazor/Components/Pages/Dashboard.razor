@page "/"
@attribute [Authorize]
@inject DocumentApiService DocumentApiService
@inject WorkflowApiService WorkflowApiService
@inject NavigationManager NavigationManager

<h1>Dashboard</h1>
<p class="muted">Tổng quan tài liệu ISO và tiến độ duyệt.</p>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <p class="error-banner" style="margin: 12px 0;">@Error</p>
}

<div class="kpi-grid">
    <article class="card kpi-card">
        <h3>Total Documents</h3>
        <strong>@TotalDocuments</strong>
    </article>
    <article class="card kpi-card">
        <h3>Draft</h3>
        <strong>@DraftCount</strong>
    </article>
    <article class="card kpi-card">
        <h3>Under Review</h3>
        <strong>@ReviewCount</strong>
    </article>
    <article class="card kpi-card">
        <h3>Pending Approvals</h3>
        <strong>@PendingApprovals</strong>
    </article>
</div>

<div class="dashboard-grid">
    <section class="card">
        <h2 style="margin-bottom: 12px;">Recent Documents</h2>
        <ul class="simple-list">
            @if (RecentDocuments.Count == 0)
            {
                <li>Chưa có dữ liệu.</li>
            }
            else
            {
                @foreach (var item in RecentDocuments)
                {
                    <li>
                        <div>
                            <button class="btn-link" @onclick="() => OpenDocument(item.Id)">@item.Title</button>
                            <div class="tiny">@item.DocumentCode • @item.OwnerName</div>
                        </div>
                        <StatusBadge Status="@item.Status" />
                    </li>
                }
            }
        </ul>
    </section>
    <section class="card">
        <h2 style="margin-bottom: 12px;">Pending Workflow</h2>
        <ul class="simple-list">
            @if (PendingItems.Count == 0)
            {
                <li>Không có task chờ duyệt.</li>
            }
            else
            {
                @foreach (var item in PendingItems)
                {
                    <li>
                        <div>
                            <b>@item.DocumentTitle</b>
                            <div class="tiny">@item.DocumentCode • Step @item.StepOrder/@item.TotalSteps</div>
                        </div>
                        <span class="tiny">@item.DaysWaiting ngày</span>
                    </li>
                }
            }
        </ul>
    </section>
</div>

@code {
    private string Error { get; set; } = string.Empty;
    private IReadOnlyList<DocumentSummaryDto> RecentDocuments { get; set; } = Array.Empty<DocumentSummaryDto>();
    private IReadOnlyList<PendingApprovalDto> PendingItems { get; set; } = Array.Empty<PendingApprovalDto>();

    private int TotalDocuments { get; set; }
    private int DraftCount { get; set; }
    private int ReviewCount { get; set; }
    private int PendingApprovals { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var recentParams = new SearchDocumentsParams { Page = 1, PageSize = 12, SortBy = "UpdatedAt", SortDesc = true };
        var draftParams = new SearchDocumentsParams { Status = "Draft", Page = 1, PageSize = 1 };
        var underParams = new SearchDocumentsParams { Status = "UnderReview", Page = 1, PageSize = 1 };
        var pendingFinalParams = new SearchDocumentsParams { Status = "PendingFinalApproval", Page = 1, PageSize = 1 };

        var recentTask = DocumentApiService.SearchAsync(recentParams);
        var totalTask = DocumentApiService.SearchAsync(new SearchDocumentsParams { Page = 1, PageSize = 1 });
        var draftTask = DocumentApiService.SearchAsync(draftParams);
        var underTask = DocumentApiService.SearchAsync(underParams);
        var pendingFinalTask = DocumentApiService.SearchAsync(pendingFinalParams);
        var pendingWorkflowTask = WorkflowApiService.GetPendingAsync(page: 1, pageSize: 20);

        await Task.WhenAll(recentTask, totalTask, draftTask, underTask, pendingFinalTask, pendingWorkflowTask);

        var (docs, _, docError) = await recentTask;
        var (_, totalPagination, totalErr) = await totalTask;
        var (_, draftPag, _) = await draftTask;
        var (_, underPag, _) = await underTask;
        var (_, pendingFinalPag, _) = await pendingFinalTask;
        var (pending, pendingPag, pendingError) = await pendingWorkflowTask;

        RecentDocuments = docs.OrderByDescending(x => x.UpdatedAt).Take(6).ToArray();
        PendingItems = pending.Take(6).ToArray();
        TotalDocuments = totalPagination?.TotalCount ?? docs.Count;
        DraftCount = draftPag?.TotalCount ?? 0;
        ReviewCount = (underPag?.TotalCount ?? 0) + (pendingFinalPag?.TotalCount ?? 0);
        PendingApprovals = pendingPag?.TotalCount ?? pending.Count;

        var err = docError ?? totalErr ?? pendingError;
        Error = string.IsNullOrWhiteSpace(err) ? string.Empty : ApiProblemMessageFormatter.Format(err);
    }

    private void OpenDocument(Guid id) => NavigationManager.NavigateTo($"/documents/{id}");
}
